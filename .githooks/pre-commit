#!/usr/bin/env bash
#
# pre-commit hook: auto-populate meta.author on *.flow.json files.
#
# For each staged flow file missing meta.author, this script looks up
# the original creator of the file via git log. It infers a GitHub @username
# from user@github.com emails, otherwise uses the git author name.
# Never overrides an existing meta.author.
#
set -euo pipefail

# All staged flow files (added or modified)
staged_flows=$(git diff --cached --name-only --diff-filter=AM -- '*.flow.json' '*.flow.jsonc' 2>/dev/null || true)

[ -z "$staged_flows" ] && exit 0

for file in $staged_flows; do
  [ -f "$file" ] || continue

  # Skip if meta.author already exists
  if python3 -c "
import json, sys
with open('$file') as f:
    data = json.load(f)
meta = data.get('meta')
if isinstance(meta, dict) and 'author' in meta:
    sys.exit(0)
sys.exit(1)
" 2>/dev/null; then
    continue
  fi

  # Look up the original creator of this file
  CREATOR_EMAIL=$(git log --diff-filter=A --follow --format='%ae' -- "$file" 2>/dev/null | tail -1)
  CREATOR_NAME=$(git log --diff-filter=A --follow --format='%an' -- "$file" 2>/dev/null | tail -1)

  # For brand-new files (no git history yet), use the current committer
  if [ -z "$CREATOR_EMAIL" ]; then
    CREATOR_EMAIL=$(git config user.email || echo "")
    CREATOR_NAME=$(git config user.name || echo "")
  fi

  # Infer GitHub username from <user>@github.com, otherwise use git name
  if [[ "$CREATOR_EMAIL" =~ ^([^@]+)@github\.com$ ]]; then
    AUTHOR="${BASH_REMATCH[1]}"
  else
    AUTHOR="$CREATOR_NAME"
  fi

  [ -z "$AUTHOR" ] && continue

  # Insert or merge meta.author into the file
  python3 -c "
import json

with open('$file', 'r') as f:
    data = json.load(f)

if 'meta' not in data or not isinstance(data.get('meta'), dict):
    data['meta'] = {}

data['meta']['author'] = '$AUTHOR'

# Preserve key order: put route first if present, then meta
ordered = {}
if 'route' in data:
    ordered['route'] = data.pop('route')
ordered['meta'] = data.pop('meta')
ordered.update(data)

with open('$file', 'w') as f:
    json.dump(ordered, f, indent=2)
    f.write('\n')
"

  git add "$file"
done
