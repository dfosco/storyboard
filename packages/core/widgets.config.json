{
  "widgets": {
    "sticky-note": {
      "label": "Sticky Note",
      "icon": "📝",
      "props": {
        "text":   { "type": "text",   "label": "Text",    "category": "content",  "default": "" },
        "color":  { "type": "select", "label": "Color",   "category": "settings", "default": "yellow",
                    "options": ["yellow", "blue", "green", "pink", "purple", "orange"] },
        "width":  { "type": "number", "label": "Width",   "category": "size", "min": 180, "default": 270 },
        "height": { "type": "number", "label": "Height",  "category": "size", "min": 60, "default": 170 }
      },
      "features": [
        { "id": "color",     "type": "color-picker", "prop": "color" },
        { "id": "copy",      "type": "action", "action": "copy" },
        { "id": "copy-link", "type": "action", "action": "copy-link" },
        { "id": "delete",    "type": "action", "action": "delete" }
      ]
    },
    "markdown": {
      "label": "Markdown",
      "icon": "📄",
      "props": {
        "content": { "type": "text",   "label": "Content", "category": "content", "default": "" },
        "width":   { "type": "number", "label": "Width",   "category": "size",    "default": 530, "min": 200, "max": 1200 }
      },
      "features": [
        { "id": "copy",      "type": "action", "action": "copy" },
        { "id": "copy-link", "type": "action", "action": "copy-link" },
        { "id": "delete",    "type": "action", "action": "delete" }
      ]
    },
    "prototype": {
      "label": "Prototype",
      "icon": "🖥️",
      "props": {
        "src":         { "type": "url",    "label": "URL",          "category": "content",  "default": "" },
        "originalSrc": { "type": "url",    "label": "Original URL", "category": "content",  "default": "" },
        "label":       { "type": "text",   "label": "Label",        "category": "settings", "default": "" },
        "zoom":        { "type": "number", "label": "Zoom",         "category": "settings", "default": 100, "min": 25, "max": 200 },
        "width":       { "type": "number", "label": "Width",        "category": "size",     "default": 800, "min": 200, "max": 2000 },
        "height":      { "type": "number", "label": "Height",       "category": "size",     "default": 600, "min": 200, "max": 1500 }
      },
      "features": [
        { "id": "open-external", "type": "action", "action": "open-external" },
        { "id": "zoom-in",  "type": "action", "action": "zoom-in" },
        { "id": "zoom-out", "type": "action", "action": "zoom-out" },
        { "id": "edit-url", "type": "action", "action": "edit" },
        { "id": "copy",      "type": "action", "action": "copy" },
        { "id": "copy-link", "type": "action", "action": "copy-link" },
        { "id": "delete",    "type": "action", "action": "delete" }
      ]
    },
    "figma-embed": {
      "label": "Figma Embed",
      "icon": "🎨",
      "props": {
        "url":    { "type": "url",    "label": "URL",    "category": "content", "default": "" },
        "width":  { "type": "number", "label": "Width",  "category": "size",    "default": 800, "min": 200, "max": 2000 },
        "height": { "type": "number", "label": "Height", "category": "size",    "default": 450, "min": 150, "max": 1500 }
      },
      "features": [
        { "id": "open-external", "type": "action", "action": "open-external" },
        { "id": "copy",      "type": "action", "action": "copy" },
        { "id": "copy-link", "type": "action", "action": "copy-link" },
        { "id": "delete",    "type": "action", "action": "delete" }
      ]
    },
    "link-preview": {
      "label": "Link Preview",
      "icon": "🔗",
      "props": {
        "url":   { "type": "url",  "label": "URL",   "category": "content", "default": "" },
        "title": { "type": "text", "label": "Title", "category": "content", "default": "" }
      },
      "features": [
        { "id": "copy",      "type": "action", "action": "copy" },
        { "id": "copy-link", "type": "action", "action": "copy-link" },
        { "id": "delete",    "type": "action", "action": "delete" }
      ]
    },
    "component": {
      "label": "Component",
      "icon": "⚛️",
      "props": {
        "width":  { "type": "number", "label": "Width",  "category": "size", "min": 100 },
        "height": { "type": "number", "label": "Height", "category": "size", "min": 60 }
      },
      "features": []
    },
    "image": {
      "label": "Image",
      "icon": "🖼️",
      "props": {
        "src":     { "type": "text",    "label": "Source",  "category": "content", "default": "" },
        "private": { "type": "boolean", "label": "Private", "category": "settings", "default": false },
        "width":   { "type": "number",  "label": "Width",   "category": "size", "min": 100 },
        "height":  { "type": "number",  "label": "Height",  "category": "size", "min": 60 }
      },
      "features": [
        { "id": "toggle-private", "type": "action", "action": "toggle-private" },
        { "id": "copy",      "type": "action", "action": "copy" },
        { "id": "copy-link", "type": "action", "action": "copy-link" },
        { "id": "delete",    "type": "action", "action": "delete" }
      ]
    }
  }
}
