{
  "name": "@dfosco/tiny-canvas",
  "version": "1.1.0",
  "type": "module",
  "license": "MIT",
  "description": "A lightweight React canvas with draggable elements and persistent positions",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./src/index.d.ts"
    },
    "./style.css": "./src/style.css"
  },
  "publishConfig": {
    "main": "./dist/tiny-canvas.js",
    "module": "./dist/tiny-canvas.js",
    "exports": {
      ".": {
        "import": "./dist/tiny-canvas.js",
        "types": "./src/index.d.ts"
      },
      "./style.css": "./dist/tiny-canvas.css"
    }
  },
  "files": [
    "dist",
    "src/index.d.ts"
  ],
  "scripts": {
    "build": "vite build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@neodrag/react": "^2.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.5"
  }
}
