{
  "devDomain": "storyboard-core",
  "repository": {
    "owner": "dfosco",
    "name": "storyboard"
  },
  "modes": {
    "enabled": false
  },
  "comments": {
    "discussions": {
      "category": "General"
    }
  },
  "featureFlags": {
    "show-banner": true,
    "dev-logs": false
  },
  "workshop": {
    "features": {
      "createPrototype": true,
      "createFlow": true,
      "createCanvas": true
    },
    "partials": [
      {
        "directory": "template",
        "name": "Application"
      }
    ]
  },
  "canvas": {
    "terminal": {
      "fontSize": 18,
      "fontFamily": "'Ghostty', 'SF Mono', 'Menlo', 'Monaco', 'Courier New', monospace",
      "prompt": "❯ ",
      "startupCommand": null,
      "defaultStartupSequence": null,
      "defaultWidth": 1200,
      "defaultHeight": 450
    },
    "agents": {
      "copilot": {
        "label": "Copilot CLI",
        "default": true,
        "icon": "primer/copilot",
        "startupCommand": "copilot --agent terminal-agent",
        "promptCommand": "copilot --agent terminal-agent -p \"${prompt}\" --allow-all",
        "postStartup": "/allow-all on",
        "readinessSignal": "Environment loaded:",
        "resizable": true
      },
      "claude": {
        "label": "Claude Code",
        "icon": "claude",
        "startupCommand": "claude --agent terminal-agent --dangerously-skip-permissions",
        "promptCommand": "claude --agent terminal-agent -p \"${prompt}\" --dangerously-skip-permissions",
        "readinessSignal": "? for shortcuts",
        "resizable": true
      },
      "codex": {
        "label": "Codex CLI",
        "icon": "codex",
        "startupCommand": "codex --full-auto",
        "readinessSignal": "default \u00b7",
        "configFiles": [".codex/config.toml"],
        "resizable": true
      }
    },
    "showAgentsInAddMenu": false
  },
  "hotPool": {
    "pool_size": 1,
    "max_pool_size": 3,
    "load_balancer": true,
    "load_balancer_cooldown_mins": 10,
    "enabled": true,
    "verbose": false
  },
  "customerMode": {
    "enabled": false,
    "hideChrome": false,
    "hideHomepage": false,
    "protoHomepage": ""
  }
}
