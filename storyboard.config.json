{
  "devDomain": "storyboard-core",
  "repository": {
    "owner": "dfosco",
    "name": "storyboard"
  },
  "modes": {
    "enabled": false
  },
  "comments": {
    "discussions": {
      "category": "General"
    }
  },
  "featureFlags": {
    "show-banner": true,
    "dev-logs": false
  },
  "workshop": {
    "features": {
      "createPrototype": true,
      "createFlow": true,
      "createCanvas": true
    },
    "partials": [
      {
        "directory": "template",
        "name": "Application"
      }
    ]
  },
  "canvas": {
    "terminal": {
      "fontSize": 18,
      "fontFamily": "'Ghostty', 'SF Mono', 'Menlo', 'Monaco', 'Courier New', monospace",
      "prompt": "❯ ",
      "startupCommand": null,
      "defaultStartupSequence": null,
      "defaultWidth": 1200,
      "defaultHeight": 450
    },
    "agents": {
      "copilot": {
        "label": "GitHub Copilot",
        "icon": "primer/copilot",
        "startupCommand": "copilot"
      },
      "claude": {
        "label": "Claude Code",
        "icon": "claude",
        "startupCommand": "claude --dangerously-skip-permissions"
      }
    }
  },
  "customerMode": {
    "enabled": false,
    "hideChrome": false,
    "hideHomepage": false,
    "protoHomepage": ""
  }
}
